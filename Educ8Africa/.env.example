# Database Configuration
# For local development:
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/training_system

# For Render production - this will be automatically set by Render:
# DATABASE_URL_RENDER=postgres://user:password@host:5432/db

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_BASE_URL=https://api.paystack.co

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Training Platform

# Application Settings
APP_NAME=Training Registration System
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Environment (development or production)
ENVIRONMENT=development

# Referral Settings
REFERRAL_COMMISSION_PERCENT=10.0

# Admin Configuration
ADMIN_EMAIL=admin@training.com
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=System Administrator
